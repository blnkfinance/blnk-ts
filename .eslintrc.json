{
  "extends": "./node_modules/gts/",
  "rules": {
    "quotes": ["error", "backtick"],
    "semi": ["error", "always"],
    "no-var": "error"
  },
  "overrides": [
    {
      "files": ["tests/**/*.ts", "tests/**/*.tsx"],
      "rules": {
        "@typescript-eslint/no-floating-promises": "off"
      }
    }
  ]
}
