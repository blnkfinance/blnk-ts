{
  "name": "@blnkfinance/blnk-typescript",
  "version": "1.3.0",
  "description": "Blnk Finance SDK in TypeScript",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "posttest": "npm run lint",
    "test:unit": "tap tests/unit"
  },
  "keywords": [
    "sdk",
    "typescript",
    "blnk",
    "finance",
    "api"
  ],
  "author": "BLNK",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "gts": "^6.0.2",
    "prettier": "^3.8.1",
    "tap": "^21.6.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "form-data": "^4.0.5"
  },
  "overrides": {
    "whatwg-url": "^16.0.1",
    "tmp": "^0.2.7"
  },
  "tap": {
    "coverage-map": "tests/map.mjs",
    "plugin": [
      "@tapjs/nock"
    ]
  }
}
